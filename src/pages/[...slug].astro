                  elevationFt={typeof post.data.elevationFt === "number" ? post.data.elevationFt : undefined}
                  county={post.data.county as string | undefined}
                  accent={themeAccent}
                />
              ) : null}
              {pestBiodiversityBundle ? (
                <PestBiodiversityPanel bundle={pestBiodiversityBundle} city={pageCity} />
              ) : null}
            </>
          ) : (
            <>
              {isFinancialPressureMode ? null : (
                <>
                  <OfficialRiskNodeHeader
                    zipCode={desktopDispatchZip}
                    stewardshipMode={isCommunityStewardshipNpo}
                  />
                  <ValueProtectionCalculator
                    homeUsd={zUsd}
                    zLabel={zLabel}
                    city={pageCity}
                    accent={themeAccent}
                    domPrefix={domPrefix}
                    terrainRiskNotice={roofTerrainNotice}
                    presentation={isCommunityStewardshipNpo ? "stewardship_provision_guide" : "value_protection"}
                    couponLinkEnabled={showFlashCoupon}
                  />
                  <NichePartnerLogos />
                </>
              )}
              <section class="hero-flood-alert-band" aria-label="Service area headline">
                <h1>
                  {
                    plumbingSerpOverride ? (
                      plumbingSerpOverride.pageH1
                    ) : roofingSerpOverride ? (
                      roofingSerpOverride.pageH1
                    ) : isFinancialPressureMode ? (
                      <>
                        {`${pageCity} ${pageNicheLabel} - Property Protection: `}
                        <span class="h1-zmoney">{zLabelForPublicSurface}</span>
                      </>
                    ) : (
                      pageH1Plain
                    )
                  }
                </h1>
                <p style="margin: 0.25rem 0 0; color: #475569; font-size: 0.98rem;">
                  {headerVariant}
                </p>
              </section>
              {isFinancialPressureMode ? (
                <>
                  <OfficialRiskNodeHeader
                    zipCode={desktopDispatchZip}
                    stewardshipMode={isCommunityStewardshipNpo}
                  />
                  <ValueProtectionCalculator
                    homeUsd={zUsd}
                    zLabel={zLabel}
                    city={pageCity}
                    accent={themeAccent}
                    domPrefix={domPrefix}
                    terrainRiskNotice={roofTerrainNotice}
                    presentation={isCommunityStewardshipNpo ? "stewardship_provision_guide" : "value_protection"}
                    couponLinkEnabled={showFlashCoupon}
                  />
                  <NichePartnerLogos />
                </>
              ) : null}
              {zUsd != null ? (
                <MarketDataView
                  seed={entrySlug}
                  city={pageCity}
                  state={stateCodeFromSlug}
                  zip={pageLocation?.zip ?? null}
                  homeUsd={zUsd}
                  elevationFt={typeof post.data.elevationFt === "number" ? post.data.elevationFt : undefined}
                  county={post.data.county as string | undefined}
                  accent={themeAccent}
                  medianContextCardTitle={isCommunityStewardshipNpo ? "Illustrative median housing context" : null}
                />
              ) : null}
            </>
          )
        }
        <div class={serviceInfoClass}>
          <h2>{ctaVariant.title}</h2>
          <p>{serviceLine}</p>
          <p class="service-meta">{ctaVariant.meta}</p>
          <TrustBar collectionKey={ACTIVE_COLLECTION} />
          {
            showLiveDispatchStatus ? (
              <LiveDispatchStatus
                city={pageCity}
                stateCode={
                  stateCodeFromSlug ??
                  stateAbbrFromNearMeSlug(entrySlug) ??
                  (String(post.data.state ?? "").trim().slice(0, 2).toUpperCase() || null)
                }
                entrySlug={entrySlug}
                lat={geo.lat}
                lng={geo.lng}
              />
            ) : null
          }
          {
            !isCommunityStewardshipNpo ? (
              <DispatchSectorRating
                city={pageCity}
                county={String(post.data.county ?? geo.county ?? "").trim()}
                state={stateCodeFromSlug}
                entrySlug={entrySlug}
                localPaths={
                  Array.isArray(post.data.localPaths)
                    ? (post.data.localPaths as string[])
                    : Array.isArray(geo.localPaths)
                      ? geo.localPaths
                      : []
                }
              />
            ) : null
          }
          <a class={`${phoneBtnClass} phone-dispatch-btn`} href={telHref} aria-label={phoneBtnAriaLabel}>
            <span class="phone-btn__main">
              <svg
                class="phone-btn__signal"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="20"
                height="20"
                aria-hidden="true"
                focusable="false"
              >
                <g fill="currentColor">
                  <rect x="3" y="14" width="3.2" height="6" rx="0.6"></rect>
                  <rect x="8.1" y="11" width="3.2" height="9" rx="0.6"></rect>
                  <rect x="13.2" y="8" width="3.2" height="12" rx="0.6"></rect>
                  <rect x="18.3" y="5" width="3.2" height="15" rx="0.6"></rect>
                </g>
              </svg>
              <span class="phone-btn__label">{callBtnLabel}</span>
            </span>
            <span class="phone-btn__trust">{phoneTrustSubtitle}</span>
          </a>
          <p class="phone-dispatch-zip-hint">{phoneZipHint}</p>
          <div class="national-dispatch-mobile-wrap">
            <NationalDispatchDisclaimer city={pageCity} slug={entrySlug} stewardshipReference={isCommunityStewardshipNpo} />
          </div>
          <p class="dispatcher-hookup-line">
            Regional coordination desk ({dispatcherCountyLabel}):
          </p>
          <p class="dispatcher-scheduling-visibility">{dispatcherClaimsLineDisplay}</p>
          {pestLatestDispatchLine ? <p class="pest-zip-dispatch-pulse">{pestLatestDispatchLine}</p> : null}
        </div>
        {
          blockOrder.map((k) => {
            if (k === "content") {
              return (
                <div id={articleBodyId} class={articleBodyClass}>
                  {sidingServiceLeadHtml ? <div set:html={sidingServiceLeadHtml} /> : null}
                  {
                    technicalAuditBodyHtml ? (
                      <>
                        {technicalAuditBodyHtml.engineeringHtml ? (
                          <div set:html={technicalAuditBodyHtml.engineeringHtml} />
                        ) : null}
                        <div set:html={technicalAuditBodyHtml.auditHtml} />
                      </>
                    ) : (
                      <Content />
                    )
                  }
                </div>
              );
            }
            if (k === "geo") {
              return showGeoSection ? (
                <section class={geoBriefClass} aria-labelledby={geoBriefTitleId}>
                  <h2 id={geoBriefTitleId}>{geoTitle}</h2>
                  {
                    showDispatchRadar ? (
                      <DispatchRadar
                        lat={geo.lat}
                        lng={geo.lng}
                        city={pageCity}
                        stateCode={stateCodeFromSlug ?? ""}
                        county={String(post.data.county ?? geo.county ?? "").trim() || null}
                        entrySlug={entrySlug}
                        zipCode={pageZipForPestPulse ?? post.data.zipCode ?? null}
                      />
                    ) : null
                  }
                  {geoCoordsLine ? <p>{geoCoordsLine}</p> : null}
                  {geoPhysicalEnvLine ? <p>{geoPhysicalEnvLine}</p> : null}
                  {localPathsText ? <p>{localPathsText}</p> : null}
                  {geo.elevationFt ? (
                    <p>
                      {elevationLabel}: {geo.elevationFt} ft (reference band).
                    </p>
                  ) : null}
                  {geo.zipCodes?.length ? (
                    <div>
                      <p style="margin-bottom: 0.25rem;">{zipSnapshotLabel}</p>
                      <details>
                        <summary style="cursor: pointer; font-weight: 600;">
                          {zipViewLabel} ({geo.zipCodes.slice(0, 12).length})
                        </summary>
                        <ul style="margin: 0.55rem 0 0; padding-left: 1.25rem;">
                          {geo.zipCodes.slice(0, 12).map((z) => (
                            <li>{z}</li>
                          ))}
                        </ul>
                      </details>
                    </div>
                  ) : null}
                  {geo.localPaths?.length ? (
                    <div style="margin-top: 0.65rem;">
                      <p style="margin-bottom: 0.25rem;">{transitLabel}</p>
                      <details>
                        <summary style="cursor: pointer; font-weight: 600;">
                          {transitViewLabel} ({geo.localPaths.slice(0, 5).length})
                        </summary>
                        <ul style="margin: 0.55rem 0 0; padding-left: 1.25rem;">
                          {geo.localPaths.slice(0, 5).map((p) => (
                            <li>{p}</li>
                          ))}
                        </ul>
                      </details>
                    </div>
                  ) : null}
                </section>
              ) : null;
            }
            if (k === "faq") {
              return showFaq ? (
                <section class={faqClass} aria-labelledby={faqTitleId}>
                  <h2 id={faqTitleId}>{faqTitle}</h2>
                  {pageFaqItemsFinal.map((item) => (
                    <details>
                      <summary>{item.question}</summary>
                      <p>{item.answer}</p>
                    </details>
                  ))}
                </section>
              ) : null;
            }
            return showRelated ? (
              <RelatedCities
                currentSlug={entrySlug}
                state={stateCodeFromSlug}
                domPrefix={domPrefix}
                themeAccent={themeAccent}
                titleText={relatedTitle}
              />
            ) : null;
          })
        }
        {
          seedLandmarks ? (
            <ServiceAreaLocalLandmarks
              city={seedReviewCityDisplay}
              state={seedLandmarksState}
              zip={seedLandmarksZip}
              landmarks={seedLandmarks.landmarks}
            />
          ) : null
        }
        {
          seedAggregateRating ? (
            <ServiceAreaVerifiedReviews
              city={seedReviewCityDisplay}
              reviewCount={seedAggregateRating.reviewCount}
            />
          ) : null
        }
      </article>
    </main>
    <Footer
      extraLink={footerExtraLink}
      notice={stateNotice}
      variantSeed={`${ACTIVE_COLLECTION}|${entrySlug}|footer`}
      slug={entrySlug}
      auditStateCode={stateCodeFromSlug}
      auditZipCode={desktopDispatchZip}
      collectionKey={ACTIVE_COLLECTION}
    />
    <DispatchCommandBar
      city={pageLocation?.city ?? pageCity ?? "Local"}
      zip={(pageLocation?.zip ?? String(post.data.zipCode ?? "").trim()) || "00000"}
      nicheLabel={pageNicheLabel}
      slugSeed={entrySlug}
    />
    <RockwellGa4Events collection={ACTIVE_COLLECTION} pageSlug={entrySlug} />
  </body>
</html>
