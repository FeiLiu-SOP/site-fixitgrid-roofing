---
import { getCollection, render } from "astro:content";
import Footer from "../components/Footer.astro";
import SiteFavicon from "../components/SiteFavicon.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import LiveDispatchFeed from "../components/LiveDispatchFeed.astro";
import MarketDataView from "../components/MarketDataView.astro";
import RelatedCities from "../components/RelatedCities.astro";
import ValueProtectionCalculator from "../components/ValueProtectionCalculator.astro";
import OfficialRiskNodeHeader from "../components/OfficialRiskNodeHeader.astro";
import TrustBar from "../components/TrustBar.astro";
import DispatchSectorRating from "../components/DispatchSectorRating.astro";
import DispatchRadar from "../components/DispatchRadar.astro";
import NationalDispatchDisclaimer from "../components/NationalDispatchDisclaimer.astro";
import NichePartnerLogos from "../components/NichePartnerLogos.astro";
import DispatchCommandBar from "../components/DispatchCommandBar.astro";
import LiveDispatchStatus from "../components/LiveDispatchStatus.astro";
import { liveDispatchStatusEnabled } from "../lib/live-dispatch-status";
import { resolveContentEntrySlug, stateAbbrFromNearMeSlug } from "../lib/fixitgrid-near-me-url";
import RockwellGa4Events from "../components/RockwellGa4Events.astro";
import ServiceAreaVerifiedReviews from "../components/ServiceAreaVerifiedReviews.astro";
import ServiceAreaLocalLandmarks from "../components/ServiceAreaLocalLandmarks.astro";
import { getGscSeedLandmarks } from "../lib/gsc-seed-landmarks";
