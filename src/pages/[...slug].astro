} from "../lib/technical-audit-report";
import { resolvePageLocation } from "../lib/location";
import {
  buildBaitPool2TitlesRoofing,
  buildRoofingH1,
  buildRoofingPageTitle,
  ROOFING_META_MAX,
} from "../lib/roofing-serp-title";
import { getRoofingSerpOverride } from "../lib/roofing-serp-overrides";
import {
  buildBaitPool2TitlesPlumbing,
  buildPlumbingH1,
  buildPlumbingPageTitle,
  PLUMBING_META_MAX,
} from "../lib/plumbing-serp-title";
import { getPlumbingSerpOverride } from "../lib/plumbing-serp-overrides";
import {
  buildBaitPool2TitlesPestcontrol,
  buildPestH1,
  buildPestNestNotice,
  buildPestPageTitle,
  PEST_META_MAX,
} from "../lib/pestcontrol-serp-title";
import { getPestcontrolSerpOverride } from "../lib/pestcontrol-serp-overrides";
import {
  buildBaitPool2TitlesWater,
  buildWaterH1,
  buildWaterPageTitle,
  WATER_META_MAX,
} from "../lib/water-damage-serp-title";
import {
  buildBaitPool2TitlesSiding,
  buildSidingH1,
  buildSidingPageTitle,
  SIDING_META_MAX,
} from "../lib/siding-serp-title";
import {
  buildBaitPool2TitlesPlumbingV2,
  buildPlumbingV2H1,
  buildPlumbingV2PageTitle,
  PLUMBING_V2_META_MAX,
} from "../lib/plumbing-v2-serp-title";
import {
  buildRockwellMaineEntityGraph,
  matchesRockwellMaine,
} from "../domain-templates/rockwell-maine-entity";
import {
  buildFixitGridEntityGraph,
  matchesFixitGridEntity,
} from "../domain-templates/fixitgrid.com-entity";
import PestBiodiversityPanel from "../components/PestBiodiversityPanel.astro";
import FlashCouponAnchor from "../components/FlashCouponAnchor.astro";
import FlashCouponVpcBridge from "../components/FlashCouponVpcBridge.astro";
import { collectionUsesFlashCoupon } from "../lib/flash-coupon";
import { buildPestBiodiversityBundle } from "../lib/pest-biodiversity";

/** Physical-value tier: deterministic title/H1 (no stableHash) when home value clears bar. */
const HIGH_VALUE_USD_TRIGGER = 300_000;

/** Monorepo: water-damage vertical (sync with `sites/site-water-damage`). */
const isWaterDamageHub = ACTIVE_COLLECTION === "water-damage";
/** Monorepo: plumbing vertical (sync with `sites/site-plumbing`). */
const isPlumbingHub = ACTIVE_COLLECTION === "plumbing";
/** Realtors siding (`sites/site-siding` / `siding-services`). */
const isSidingHub = ACTIVE_COLLECTION === "siding-services";
/** Realtors plumbing-v2 (`sites/site-plumbing-v2`, `/plumbing/` hub). */
const isPlumbingV2Hub = ACTIVE_COLLECTION === "plumbing-v2";
/** Rockwell roofing vertical (`sites/site-roofing` terrain-notice funnel). */
const isRoofingHub = ACTIVE_COLLECTION === "roofing";
/** Rockwell pest control (`sites/site-pestcontrol`). */
const isPestControlHub = ACTIVE_COLLECTION === "pestcontrol";
/** Newtown Fellowship / church city pages (`npm run build:community-stewardship-*`). */
const isCommunityStewardshipNpo = ACTIVE_COLLECTION.startsWith("community-stewardship-");
/** Red Flash Offer bar — all 6 commercial hubs (not church / NPO). */
const showFlashCoupon = collectionUsesFlashCoupon(ACTIVE_COLLECTION);

export async function getStaticPaths() {
  const { entryPublicPathSegments } = await import("../lib/fixitgrid-near-me-url");
  const posts = await getCollection(ACTIVE_COLLECTION);
  return posts.map((post) => {
    const entrySlug = (post.slug ?? post.id ?? "").replace(/\.(md|mdx)$/i, "");
    const stateAbbr =
      typeof post.data.state === "string" ? post.data.state.trim().slice(0, 2).toUpperCase() : undefined;
    const segments = entryPublicPathSegments(entrySlug, stateAbbr);
    return { params: { slug: segments.join("/") } };
  });
}

const { slug } = Astro.params;
const posts = await getCollection(ACTIVE_COLLECTION);
const entrySlugParam = resolveContentEntrySlug(slug ?? "");
const entry =
  posts.find((p) => (p.slug ?? p.id ?? "").replace(/\.(md|mdx)$/i, "") === entrySlugParam) ?? null;
if (!entry) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}
const { Content } = await render(entry);
const post = entry;
const markdownBody = resolveCollectionEntryMarkdownBody(entry, ACTIVE_COLLECTION);
const entrySlug = entrySlugParam || (post.slug ?? post.id ?? "").replace(/\.(md|mdx)$/i, "");
const pageUrl = canonicalPageUrl(entrySlug);
const ogImageUrl = ogThumbnailUrl(entrySlug);
const pageNicheLabel = getNicheLabelForSeed(entrySlug);
const isRockwellMaine = matchesRockwellMaine({ domainOrUrl: siteConfig.canonicalOrigin });
const isFixitGridSite = matchesFixitGridEntity({ domainOrUrl: siteConfig.canonicalOrigin });
const pageLocation = resolvePageLocation({
  collection: ACTIVE_COLLECTION,
  title: post.data.title,
  slug: entrySlug,
  fmCity: post.data.city,
  fmState: post.data.state,
  fmZip: post.data.zipCode,
});
function titleCase(s: string) {
  return s
    .split(/\s+/g)
    .filter(Boolean)
    .map((w) => w.slice(0, 1).toUpperCase() + w.slice(1))
    .join(" ");
}
function cityFromSlug(slugText: string) {
  const m = slugText.match(/^(.*)-([a-z]{2})-(\d{5})$/i);
  if (!m) return null;
  let prefixAndCity = m[1]!;
  const stripPrefixes = [`${String(ACTIVE_COLLECTION)}-`.toLowerCase()];
  if (ACTIVE_COLLECTION === "pestcontrol") stripPrefixes.push("pest-control-");
  for (const pfx of stripPrefixes) {
    if (prefixAndCity.toLowerCase().startsWith(pfx)) {
      prefixAndCity = prefixAndCity.slice(pfx.length);
      break;
    }
  }
  const city = prefixAndCity.split("-").filter(Boolean).join(" ").trim();
  return city ? titleCase(city) : null;
}
const pageCityFromSlug = cityFromSlug(entrySlug);
const pageCity = String(post.data.city ?? "").trim() || pageCityFromSlug;
/** Opt-in live OPEN / after-hours bar — PUBLIC_LIVE_DISPATCH_STATUS=1; never on church pages. */
const showLiveDispatchStatus =
  liveDispatchStatusEnabled() && !isCommunityStewardshipNpo && Boolean(pageCity?.trim());
const trustDispatchPlace = pageCity?.trim() ? pageCity.trim() : "Area";
const desktopDispatchZip =
  String(pageLocation?.zip ?? post.data.zipCode ?? "")
    .replace(/\D/g, "")
    .slice(0, 5) || "00000";
const stateCodeFromSlug = (() => {
  const m = entrySlug.match(/-([a-z]{2})-\d{5}$/i);
  return m ? m[1]!.toUpperCase() : null;
})();
const technicalAuditBodyHtml =
  usesTechnicalAuditReport(ACTIVE_COLLECTION) && markdownBody
    ? buildTechnicalAuditBodyHtml({
        body: markdownBody,
        fm: {
          city: pageCity,
          state: stateCodeFromSlug ?? String(post.data.state ?? ""),
          county: String(post.data.county ?? ""),
          zipCode: String(post.data.zipCode ?? ""),
        },
        slug: entrySlug,
        nicheLabel: pageNicheLabel,
      })
    : null;
// Action 1: footer random internal link from backup pool (state index + random city)
const backupCandidates: { href: string; label: string }[] = [];
if (stateCodeFromSlug) {
  backupCandidates.push({
    href: internalPath(stateCodeFromSlug.toLowerCase()),
    label: `Browse ${pageNicheLabel} in ${stateCodeFromSlug}`,
  });
}
const other = posts.filter((p) => (p.slug ?? p.id ?? "").replace(/\.(md|mdx)$/i, "") !== entrySlug);
if (other.length > 0) {
  const pick = other[Math.floor(Math.random() * other.length)]!;
  const pickSlug = (pick.slug ?? pick.id ?? "").replace(/\.(md|mdx)$/i, "");
  backupCandidates.push({
    href: internalPath(pickSlug),
    label: `Another ${pageNicheLabel} page`,
  });
}
const footerExtraLink =
  backupCandidates.length > 0 ? backupCandidates[Math.floor(Math.random() * backupCandidates.length)]! : null;

type DispatchFeedRecord = {
  city: string;
  state: string;
  offset: number;
  tag: "[NODE ACTIVE]" | "[DISPATCH CONFIRMED]";
};

function shuffledDispatch<T>(arr: T[]): T[] {
  const out = [...arr];
  for (let i = out.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [out[i], out[j]] = [out[j]!, out[i]!];
  }
  return out;
}

function cityLabelFromEntry(entry: (typeof posts)[number]): string {
  const c = entry.data.city?.trim();
  if (c) return titleCase(c);
  const slugText = (entry.slug ?? entry.id ?? "").replace(/\.(md|mdx)$/i, "");
  return cityFromSlug(slugText) ?? "Unknown City";
}

/** Water-damage city pages: optional ledger (parity with `sites/site-water-damage` state hub). */
const slugDispatchFeedRecords: DispatchFeedRecord[] = (() => {
  if (!isWaterDamageHub || !stateCodeFromSlug) return [];
  const st = stateCodeFromSlug.toUpperCase();
  const sameState = posts.filter((p) => {
    const s = (p.slug ?? p.id ?? "").replace(/\.(md|mdx)$/i, "");
    const m = s.match(/-([a-z]{2})-\d{5}$/i);
    return m && m[1]!.toUpperCase() === st && s !== entrySlug;
  });
  if (sameState.length === 0) return [];
  return shuffledDispatch(sameState.map((p) => ({ city: cityLabelFromEntry(p), state: st })))
    .slice(0, 8)
    .map((item, idx) => ({
      ...item,
      offset: 5 + Math.floor(Math.random() * 51),
      tag: (idx % 2 === 0 ? "[NODE ACTIVE]" : "[DISPATCH CONFIRMED]") as DispatchFeedRecord["tag"],
    }));
})();

const faqPool = getFaqPoolByCollection(ACTIVE_COLLECTION);
function stableHash(input: string) {
  let h = 2166136261;
  for (let i = 0; i < input.length; i++) {
    h ^= input.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}
function formatZillowUsdShort(usd: number): string {
  if (!Number.isFinite(usd) || usd <= 0) return "";
  if (usd >= 1_000_000) {
    const m = usd / 1_000_000;
    const s =
      m >= 10
        ? String(Math.round(m))
        : String(Math.round(m * 100) / 100).replace(new RegExp("\\.?0+$"), "");
    return `$${s}M`;
  }
  const k = usd / 1000;
  if (k < 10) return `$${Math.round(usd).toLocaleString("en-US")}`;
  const roundedK = Math.round(k * 10) / 10;
  const sk = Number.isInteger(roundedK) ? String(roundedK) : roundedK.toFixed(1).replace(/\.0$/, "");
  return `$${sk}K`;
}
function clipMetaDescription(text: string, max = 158): string {
  const t = text.trim();
  if (t.length <= max) return t;
  return `${t.slice(0, max - 1).trimEnd().replace(/[,;\s]+$/, "")}…`;
}

function stateLabelForBait(stateCode: string, stateFromFm: string | undefined): string {
  const fm = (stateFromFm ?? "").trim();
  if (fm.length > 2) return fm;
  return stateCode;
}

function buildBaitPool2TitlesLegacy(opts: {
  service: string;
  city: string;
  stateCode: string;
  stateFm: string | undefined;
  zLabel: string | null;
  pick: number;
}): { pageTitle: string; pageH1: string } {
  const stateToken = stateLabelForBait(opts.stateCode, opts.stateFm);
  const { service, city, zLabel, pick } = opts;
  if (pick === 0 && zLabel) {
    const pageTitle = `${zLabel} Home Protection: ${city} Emergency ${service} (Verified)`;
    const pageH1 = `${zLabel} Home Protection — ${city} Emergency ${service}`;
    return { pageTitle, pageH1 };
  }
  if (pick === 1) {
    const pageTitle = `${city} ${service} — 24/7 coordinated intake (${stateToken})`;
    const pageH1 = `${city} ${service}: regional coordination desk (${stateToken})`;
    return { pageTitle, pageH1 };
  }
  const pageTitle = `Maintenance intensity signal in ${city}. Coordinated ${service} planning.`;
  const pageH1 = `Maintenance intensity signal in ${city} — coordinated ${service} planning`;
  return { pageTitle, pageH1 };
}

/** Stewardship HTML: avoid `$123` substrings (church compliance `usd_amount`). */
function stewardshipPlainHomeValue(usd: number): string {
  return `${new Intl.NumberFormat("en-US", { maximumFractionDigits: 0 }).format(usd)} USD (reference)`;
}

function buildStewardshipNpoBaitTitles(opts: {
  service: string;
  city: string;
  stateCode: string;
  stateFm: string | undefined;
  pick: number;
}): { pageTitle: string; pageH1: string } {
  const stateToken = stateLabelForBait(opts.stateCode, opts.stateFm);
  const { service, city, pick } = opts;
  const r = pick % 3;
  if (r === 0) {
    return {
      pageTitle: `${city} ${service} stewardship reference (${stateToken})`,
      pageH1: `${city} ${service} — neighbor-stewardship intake notes (${stateToken})`,
    };
  }
  if (r === 1) {
    return {
      pageTitle: `${city} volunteer coordination context (${stateToken}) — ${service}`,
      pageH1: `${city} ${service}: educational coordination context (${stateToken})`,
    };
  }
  return {
    pageTitle: `${service} neighborhood stewardship brief — ${city}, ${stateToken}`,
    pageH1: `Maintenance education brief for ${city} (${stateToken}) — ${service}`,
  };
}

const zRaw = post.data.zillowHomeValueUsd;
const zUsd =
  typeof zRaw === "number" && Number.isFinite(zRaw) && zRaw > 0 ? zRaw : null;
const zLabel = zUsd != null ? formatZillowUsdShort(zUsd) : null;
const zLabelExact =
  zUsd != null
    ? new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD",
        maximumFractionDigits: 0,
      }).format(zUsd)
    : null;
/** Public HTML / meta: church builds avoid `$` + digits (compliance `usd_amount`). */
const zLabelForPublicSurface =
  isCommunityStewardshipNpo && zUsd != null ? stewardshipPlainHomeValue(zUsd) : zLabelExact;
const baitPickRaw = stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|bait2`) % 3;
let baitPick = baitPickRaw;
if (
  !isWaterDamageHub &&
  !isPlumbingHub &&
  !isPlumbingV2Hub &&
  !isSidingHub &&
  !isRoofingHub &&
  !isPestControlHub &&
  baitPick === 0 &&
  !zLabel
) {
  baitPick = 1 + (stableHash(`${ACTIVE_COLLECTION}|${entrySlug}|bait2NoZ`) % 2);
}
const isFinancialPressureMode =
  zUsd != null &&
  zUsd >= HIGH_VALUE_USD_TRIGGER &&
  zLabelExact != null &&
  pageCity != null;
const isRoofingHighValue = isRoofingHub && isFinancialPressureMode;
const isPlumbingHighValue = isPlumbingHub && isFinancialPressureMode;
const isPestHighValue = isPestControlHub && isFinancialPressureMode;
const isWaterHighValue = isWaterDamageHub && isFinancialPressureMode;
const roofingConvHead =
  isRoofingHub && pageCity
    ? buildBaitPool2TitlesRoofing({
        city: pageCity,
        zLabel,
        zLabelExact,
        highValue: isRoofingHighValue,
        slug: entrySlug,
        stateCode: stateCodeFromSlug ?? "US",
      })
    : null;
const roofingSerpOverride = isRoofingHub ? getRoofingSerpOverride(entrySlug) : null;
const plumbingSerpOverride = isPlumbingHub ? getPlumbingSerpOverride(entrySlug) : null;
const pestSerpOverride = isPestControlHub ? getPestcontrolSerpOverride(entrySlug) : null;
const plumbingConvHead =
  isPlumbingHub && pageCity && stateCodeFromSlug
    ? buildBaitPool2TitlesPlumbing({
        city: pageCity,
        stateCode: stateCodeFromSlug,
        zLabel,
        zLabelExact,
        highValue: isPlumbingHighValue,
        slug: entrySlug,
      })
    : null;
const pestConvHead =
  isPestControlHub && pageCity && stateCodeFromSlug
    ? buildBaitPool2TitlesPestcontrol({
        city: pageCity,
        stateCode: stateCodeFromSlug,
        zLabel,
        zLabelExact,
        highValue: isPestHighValue,
        slug: entrySlug,
        pick: baitPickRaw,
      })
    : null;
const waterConvHead =
  isWaterDamageHub && pageCity && stateCodeFromSlug
    ? buildBaitPool2TitlesWater({
        city: pageCity,
        stateCode: stateCodeFromSlug,
        zLabel,
        zLabelExact,
        highValue: isWaterHighValue,
        slug: entrySlug,
        pick: baitPickRaw,
      })
    : null;
const sidingConvHead =
  isSidingHub && pageCity && stateCodeFromSlug
    ? buildBaitPool2TitlesSiding({
        city: pageCity,
        stateCode: stateCodeFromSlug,
        zLabel,
        zLabelExact,
        slug: entrySlug,
        pick: baitPickRaw,
      })
    : null;
const plumbingV2ConvHead =
  isPlumbingV2Hub && pageCity && stateCodeFromSlug
    ? buildBaitPool2TitlesPlumbingV2({
        city: pageCity,
        stateCode: stateCodeFromSlug,
        zLabel,
        zLabelExact,
        slug: entrySlug,
        pick: baitPickRaw,
      })
    : null;
const baitHead =
  pageCity && stateCodeFromSlug
    ? isCommunityStewardshipNpo
          ? buildStewardshipNpoBaitTitles({
              service: pageNicheLabel,
              city: pageCity,
              stateCode: stateCodeFromSlug,
              stateFm: post.data.state,
              pick: baitPick,
            })
          : buildBaitPool2TitlesLegacy({
              service: pageNicheLabel,
              city: pageCity,
              stateCode: stateCodeFromSlug,
              stateFm: post.data.state,
              zLabel,
              pick: baitPick,
            })
    : null;
const waterVisualLine = pageCity
  ? `Urgent Notice: Your ${pageCity} property terrain data indicates high-risk saturation levels. Immediate structural drying is required to prevent mold colonization.`
  : `Urgent Notice: Your property terrain data indicates high-risk saturation levels. Immediate structural drying is required to prevent mold colonization.`;

/** Avoid `$`+digit and `dispatch fee` substrings (church HTML compliance scans strip JSON-LD but not `<title>`/body). */
const h1ComplianceLead = "No surprise trip framing · upfront scope notes — ";

const plumbingVisualLine = pageCity
  ? `Our ${pageCity} dispatch node ensures state-compliant pricing. Cross-referenced with USGS infrastructure risk scores to prevent plumbing scams.`
  : `Our dispatch node ensures state-compliant pricing. Cross-referenced with USGS infrastructure risk scores to prevent plumbing scams.`;

const sidingVisualLine = pageCity
  ? `Our ${pageCity} dispatch node ensures state-compliant pricing. Cross-referenced with envelope risk scores to prevent exterior contractor scams.`
  : `Our dispatch node ensures state-compliant pricing. Cross-referenced with envelope risk scores to prevent exterior contractor scams.`;

const roofTerrainNotice = isRoofingHub
  ? pageCity
    ? `NOTICE: Your ${pageCity} property has a specific terrain-risk profile. Delaying repair could impact insurance eligibility.`
    : null
  : null;

const pestNestNotice =
  isPestControlHub && pageCity ? buildPestNestNotice(pageCity) : null;

/** `<title>` / JSON-LD name */
const pageTitle = isWaterDamageHub
  ? waterConvHead?.pageTitle ??
    (pageCity
      ? buildWaterPageTitle({
          city: pageCity,
          zLabel,
          zLabelExact,
          highValue: isWaterHighValue,
          slug: entrySlug,
          pick: baitPickRaw,
        })
      : post.data.title)
  : isPlumbingHub
    ? plumbingSerpOverride?.pageTitle ??
      plumbingConvHead?.pageTitle ??
      (pageCity
        ? buildPlumbingPageTitle({
            city: pageCity,
            zLabel,
            zLabelExact,
            highValue: isPlumbingHighValue,
            slug: entrySlug,
          })
        : post.data.title)
    : isPlumbingV2Hub
      ? plumbingV2ConvHead?.pageTitle ??
        (pageCity
          ? buildPlumbingV2PageTitle({
              city: pageCity,
              zLabel,
              zLabelExact,
              slug: entrySlug,
              pick: baitPickRaw,
            })
          : post.data.title)
      : isSidingHub
      ? sidingConvHead?.pageTitle ??
        (pageCity
          ? buildSidingPageTitle({
              city: pageCity,
              zLabel,
              zLabelExact,
              slug: entrySlug,
              pick: baitPickRaw,
            })
          : post.data.title)
      : isRoofingHub
      ? roofingSerpOverride?.pageTitle ??
        roofingConvHead?.pageTitle ??
        (pageCity
          ? buildRoofingPageTitle({
              city: pageCity,
              zLabel,
              zLabelExact,
              highValue: isRoofingHighValue,
              slug: entrySlug,
            })
          : buildRoofingPageTitle({
              city: "Local",
              zLabel,
              zLabelExact,
              highValue: false,
              slug: entrySlug,
            }))
      : isPestControlHub
        ? pestSerpOverride?.pageTitle ??
          pestConvHead?.pageTitle ??
          (pageCity
            ? buildPestPageTitle({
                city: pageCity,
                zLabel,
                zLabelExact,
                highValue: isPestHighValue,
                slug: entrySlug,
                pick: baitPickRaw,
              })
            : post.data.title)
        : isFinancialPressureMode
          ? `${zLabelForPublicSurface} asset stewardship brief: ${pageCity} ${pageNicheLabel} (coordinated intake)`
          : baitHead?.pageTitle ?? post.data.title;

/** Visible `<h1>` fallback */
const pageH1Plain = isWaterDamageHub
  ? waterConvHead?.pageH1 ??
    (pageCity
      ? buildWaterH1({ city: pageCity, zLabel, zLabelExact })
      : post.data.title)
  : isPlumbingHub
    ? plumbingSerpOverride?.pageH1 ??
      plumbingConvHead?.pageH1 ??
      (pageCity
        ? buildPlumbingH1({
            city: pageCity,
            zLabel,
            zLabelExact,
            highValue: isPlumbingHighValue,
          })
        : post.data.title)
    : isPlumbingV2Hub
      ? plumbingV2ConvHead?.pageH1 ??
        (pageCity
          ? buildPlumbingV2H1({ city: pageCity, zLabel, zLabelExact })
          : post.data.title)
      : isSidingHub
      ? sidingConvHead?.pageH1 ??
        (pageCity
