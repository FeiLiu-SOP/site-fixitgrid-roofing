import { ACTIVE_COLLECTION } from "../active-collection";
import {
  BRAND_CONFIG,
  canonicalPageUrl,
  getCanonicalBase,
  getNicheLabelForSeed,
  internalPath,
  siteConfig,
} from "../site-config";
import {
  REALTORS_AT_THE_BEACH_WATER_DAMAGE,
  matchesRealtorsAtTheBeachWaterDamage,
} from "../domain-templates/realtorsatthebeach.com-water-damage";
import {
  REALTORS_AT_THE_BEACH_PLUMBING_V2,
} from "../domain-templates/realtorsatthebeach.com-plumbing-v2";
import { buildBreadcrumbListSchema, buildSlugPageBreadcrumbItems } from "../lib/breadcrumb-schema";
import { getStatePhysicalEnvironmentFact } from "../lib/geo-facts";
import {
  buildFaqSchema,
  buildLocalBusinessSchema,
  buildNewtownFellowshipLocalBusinessSchema,
  buildServiceAreaAggregateRating,
  getFaqPoolByCollection,
} from "../lib/seo";
import { buildHydratedPageFaqs, type FaqHydrationContext } from "../lib/faq-hydration";
import {
  buildTechnicalAuditBodyHtml,
  resolveCollectionEntryMarkdownBody,
