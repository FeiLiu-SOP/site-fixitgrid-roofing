---
import { buildDispatchRadarBundle } from "../lib/dispatch-radar";

const {
  lat,
  lng,
  city,
  stateCode,
  county = null,
  entrySlug,
  zipCode = null,
} = Astro.props as {
  lat: number;
  lng: number;
  city: string;
  stateCode: string;
  county?: string | null;
  entrySlug: string;
  zipCode?: string | null;
};

const googleApiKey =
  import.meta.env.GOOGLE_STATIC_MAPS_API_KEY ??
  import.meta.env.PUBLIC_GOOGLE_STATIC_MAPS_API_KEY ??
  process.env.GOOGLE_STATIC_MAPS_API_KEY ??
  null;

const warRoom = buildDispatchRadarBundle({
  lat,
  lng,
  city,
  stateCode,
  county,
  entrySlug,
  zipCode,
  googleApiKey,
});

const cityLabel = city.trim() || "Local";
const tileGridPx = (warRoom.tileGridSize ?? 0) * (warRoom.tileSize ?? 256);
const tileCenterIdx = Math.floor((warRoom.tileGridSize ?? 5) / 2);

/** Always at least one line; duplicated in DOM for seamless -50% marquee loop. */
const tickerLines =
  warRoom.tickerLines.length > 0
    ? warRoom.tickerLines
    : [`[00:00:00] - Dispatch: ${cityLabel} sector nominal`];
/** ~11 chars/s scroll speed; clamp keeps motion readable on mobile. */
const tickerDurationSec = Math.max(
  28,
  Math.min(64, Math.round(tickerLines.join("").length / 11)),
);
---

<section
  class="dispatch-radar"
  aria-label={`Geospatial deployment — ${cityLabel}`}
  data-dispatch-sig={warRoom.jitter.sigCode}
  data-dispatch-ch={warRoom.jitter.channel}
  data-hue-rotate={String(warRoom.jitter.hueRotateDeg)}
>
  <div class="dispatch-radar__shell">
    <header class="dispatch-radar__header">
      <h2 class="dispatch-radar__section-title">Geospatial Deployment Analysis</h2>
      <p class="dispatch-radar__lock">
        {warRoom.nodeLockTitle}
        {warRoom.zoneStatus ? (
          <span class="dispatch-radar__zone"> · {warRoom.zoneStatus}</span>
        ) : null}
      </p>
      <p class="dispatch-radar__sub">
        Residential detail · zoom {warRoom.zoom} · {warRoom.jitter.sigCode} · {warRoom.jitter.channel} · lock{" "}
        {warRoom.centerLat.toFixed(4)}, {warRoom.centerLng.toFixed(4)}
        {warRoom.landCorrected ? " · land anchor" : ""}
      </p>
      {warRoom.coastalAnchorNote ? (
        <p class="dispatch-radar__coastal-note">{warRoom.coastalAnchorNote}</p>
      ) : null}
    </header>

    <div
      class="dispatch-radar__stack"
      style={`filter: hue-rotate(${warRoom.jitter.hueRotateDeg}deg)`}
    >
      <div class="dispatch-radar__frame">
        {
          warRoom.provider === "google" && warRoom.imageUrl ? (
            <img
              class="dispatch-radar__map"
              src={warRoom.imageUrl}
              alt={warRoom.alt}
              title={warRoom.title}
              width="400"
              height="300"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          ) : warRoom.tiles ? (
            <div class="dispatch-radar__tiles" role="img" aria-label={warRoom.alt} title={warRoom.title}>
              <div
                class="dispatch-radar__tiles-inner"
                style={{
                  width: `${tileGridPx}px`,
                  height: `${tileGridPx}px`,
                  transform: `translate(${warRoom.tileTranslateX}px, ${warRoom.tileTranslateY}px)`,
                }}
              >
                {
                  warRoom.tiles.map((tile) => {
                    const isCenter =
                      tile.col === tileCenterIdx && tile.row === tileCenterIdx;
                    return (
                      <img
                        class="dispatch-radar__tile"
                        src={tile.url}
                        alt=""
                        aria-hidden="true"
                        width={warRoom.tileSize}
                        height={warRoom.tileSize}
                        loading={isCenter ? "eager" : "lazy"}
                        fetchpriority={isCenter ? "high" : undefined}
                        decoding="async"
                        style={{
                          left: `${tile.col * (warRoom.tileSize ?? 256)}px`,
                          top: `${tile.row * (warRoom.tileSize ?? 256)}px`,
                        }}
                      />
                    );
                  })
                }
              </div>
            </div>
          ) : null
        }

        <div class="dispatch-radar__mesh" aria-hidden="true">
          {
            warRoom.provider === "osm-tiles"
              ? warRoom.projectedNodes.map((p) => (
                  <span
                    class:list={[
                      "dispatch-radar__dot",
                      p.node.active ? "dispatch-radar__dot--active" : "dispatch-radar__dot--mesh",
                    ]}
                    style={{ left: `${p.xPct}%`, top: `${p.yPct}%` }}
                    title={p.node.label}
                  />
                ))
              : null
          }
          <div class="dispatch-radar__active-node">
            <span class="dispatch-radar__sonar dispatch-radar__sonar--a" />
            <span class="dispatch-radar__sonar dispatch-radar__sonar--b" />
            <span class="dispatch-radar__active-core" />
          </div>
        </div>

        <p class="dispatch-radar__node">{warRoom.nodeLabel}</p>
      </div>

      <div
        class="dispatch-radar__ticker"
        aria-live="polite"
        aria-label={`Live dispatch monitor — ${cityLabel}`}
      >
        <span class="dispatch-radar__online" aria-hidden="true">● ONLINE</span>
        <div class="dispatch-radar__ticker-viewport">
          <div
            class="dispatch-radar__ticker-track"
            style={`--dispatch-ticker-duration: ${tickerDurationSec}s`}
          >
            <div class="dispatch-radar__ticker-segment">
              {
                tickerLines.map((line) => (
                  <span class="dispatch-radar__ticker-item">{line}</span>
                ))
              }
            </div>
            <div class="dispatch-radar__ticker-segment" aria-hidden="true">
              {
                tickerLines.map((line) => (
                  <span class="dispatch-radar__ticker-item">{line}</span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>

    <p class="dispatch-radar__footnote">{warRoom.gridFootnote}</p>
    <p class="dispatch-radar__caption">
      Local node lock · {warRoom.projectedNodes.length} mesh nodes in frame ·{" "}
      {warRoom.provider === "google" ? "Google Static Maps" : "OSM tile mesh (preview)"}
    </p>
  </div>
</section>

<style>
  .dispatch-radar {
    box-sizing: border-box;
    width: 100%;
    margin: 1rem 0 1.25rem;
  }
  .dispatch-radar__shell {
    box-sizing: border-box;
    width: 100%;
    padding: 0.9rem 0.95rem 0.85rem;
    border-radius: 8px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
  }
  .dispatch-radar__header {
    margin: 0 0 0.7rem;
  }
  .dispatch-radar__section-title {
    margin: 0 0 0.3rem;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #0f172a;
    line-height: 1.3;
  }
  .dispatch-radar__lock {
    margin: 0 0 0.25rem;
    font-family: "JetBrains Mono", "Courier New", Courier, ui-monospace, monospace;
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.35;
    color: #1e293b;
  }
  .dispatch-radar__zone {
    font-weight: 600;
    color: #0369a1;
  }
  .dispatch-radar__coastal-note {
    margin: 0.35rem 0 0;
    font-size: 0.72rem;
    line-height: 1.45;
    color: #475569;
    font-style: italic;
  }
  .dispatch-radar__sub {
    margin: 0;
    font-size: 0.76rem;
    line-height: 1.4;
    color: #64748b;
  }
  .dispatch-radar__stack {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #94a3b8;
    background: #0f172a;
  }
  .dispatch-radar__frame {
    position: relative;
    width: 100%;
    margin: 0;
    aspect-ratio: 4 / 3;
    background: #0f172a;
  }
  .dispatch-radar__map,
  .dispatch-radar__tiles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .dispatch-radar__map {
    display: block;
    object-fit: cover;
  }
  .dispatch-radar__tiles {
    overflow: hidden;
  }
  .dispatch-radar__tiles-inner {
    position: absolute;
    top: 0;
    left: 0;
    will-change: transform;
  }
  .dispatch-radar__tile {
    position: absolute;
    display: block;
    width: 256px;
    height: 256px;
  }
  .dispatch-radar__mesh {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }
  .dispatch-radar__dot {
    position: absolute;
    transform: translate(-50%, -50%);
    border-radius: 50%;
  }
  .dispatch-radar__dot--mesh {
    width: 7px;
    height: 7px;
    background: rgba(148, 163, 184, 0.95);
    box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.35);
  }
  .dispatch-radar__dot--active {
    display: none;
  }
  .dispatch-radar__active-node {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 16px;
    height: 16px;
  }
  .dispatch-radar__active-core {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ef4444;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.9);
    z-index: 3;
  }
  .dispatch-radar__sonar {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid rgba(255, 0, 0, 0.4);
    background: rgba(255, 0, 0, 0.12);
    animation: sonar-ping 2.6s ease-out infinite;
    z-index: 1;
  }
  .dispatch-radar__sonar--b {
    animation-delay: 1.3s;
  }
  @keyframes sonar-ping {
    0% {
      transform: scale(1);
      opacity: 0.85;
    }
    100% {
      transform: scale(3);
      opacity: 0;
    }
  }
  .dispatch-radar__node {
    position: absolute;
    right: 0.45rem;
    bottom: 0.4rem;
    margin: 0;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    background: rgba(15, 23, 42, 0.78);
    color: #6ee7b7;
    font-family: "JetBrains Mono", "Courier New", Courier, ui-monospace, monospace;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1.35;
    max-width: calc(100% - 0.9rem);
    overflow-wrap: anywhere;
    z-index: 4;
  }
  .dispatch-radar__ticker {
    display: flex;
    align-items: stretch;
    width: 100%;
    margin: 0;
    background: #0f172a;
    border-top: 1px solid #1e293b;
  }
  .dispatch-radar__online {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.55rem;
    font-family: "JetBrains Mono", "Courier New", Courier, ui-monospace, monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #22c55e;
    background: #0f172a;
    border-right: 1px solid #1e293b;
    white-space: nowrap;
  }
  .dispatch-radar__ticker-viewport {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
  }
  .dispatch-radar__ticker-track {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    width: max-content;
    min-height: 2rem;
    will-change: transform;
    animation: dispatch-ticker var(--dispatch-ticker-duration, 42s) linear infinite;
  }
  .dispatch-radar__ticker-segment {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    gap: 2.25rem;
    padding: 0.38rem 0.65rem;
  }
  .dispatch-radar__ticker-item {
    flex: 0 0 auto;
    font-family: "JetBrains Mono", "Courier New", Courier, ui-monospace, monospace;
    font-size: 11px;
    font-weight: 600;
    color: #6ee7b7;
    white-space: nowrap;
  }
  @keyframes dispatch-ticker {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .dispatch-radar__footnote {
    margin: 0.55rem 0 0;
    font-family: "JetBrains Mono", "Courier New", Courier, ui-monospace, monospace;
    font-size: 0.62rem;
    line-height: 1.4;
    color: #94a3b8;
    text-align: center;
    letter-spacing: 0.02em;
  }
  .dispatch-radar__caption {
    margin: 0.25rem 0 0;
    font-size: 0.74rem;
    line-height: 1.4;
    color: #64748b;
    text-align: center;
  }
  @media (max-width: 479px) {
    .dispatch-radar__shell {
      padding: 0.75rem 0.7rem 0.7rem;
    }
    .dispatch-radar__online,
    .dispatch-radar__ticker-item {
      font-size: 10px;
    }
    .dispatch-radar__node {
      font-size: 0.54rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .dispatch-radar__sonar,
    .dispatch-radar__ticker-track {
      animation: none;
      transform: none;
    }
    .dispatch-radar__sonar {
      opacity: 0.35;
    }
    .dispatch-radar__ticker-segment[aria-hidden="true"] {
      display: none;
    }
    .dispatch-radar__ticker-viewport {
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
    }
  }
</style>
