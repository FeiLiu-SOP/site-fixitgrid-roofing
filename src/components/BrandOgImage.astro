---
import {
  brandHeroOgImageUrl,
  brandProfileForActiveBuild,
} from "../lib/brand-visual-profile";

const ogImage = brandHeroOgImageUrl();
const profile = brandProfileForActiveBuild();
---

{
  ogImage && (
    <>
      <meta property="og:image" content={ogImage} />
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
      <meta property="og:image:alt" content={profile?.headline ?? "Brand service coverage map"} />
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:image" content={ogImage} />
    </>
  )
}
