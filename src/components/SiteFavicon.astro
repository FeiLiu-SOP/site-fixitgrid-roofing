---
import { trustShieldFaviconHref } from "../lib/brand-visual-profile";

const shieldSvg = trustShieldFaviconHref();
---
{shieldSvg ? (
  <>
    <!-- SVG trust shield (modern browsers + Google SERP); omitted on church / stewardship builds -->
    <link rel="icon" type="image/svg+xml" href={shieldSvg} />
    <!-- iOS home screen -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <!-- 48x48 PNG fallback (Google / legacy browsers) -->
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
  </>
) : null}
