---
import { buildFlashCouponVpcPopupMessage } from "../lib/flash-coupon-vpc-message";

const { city, entrySlug, calculatorRootId } = Astro.props as {
  city: string;
  entrySlug: string;
  calculatorRootId: string;
};

const msg = buildFlashCouponVpcPopupMessage(city);
const popupId = "vpc-coupon-popup";
---

<!-- SSR shell (hidden) — no extra network; ~1.5KB inline bridge script below -->
<div
  id={popupId}
  class="vpc-coupon-popup"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${popupId}-title`}
  hidden
  data-vpc-target={calculatorRootId}
  data-flash-slug={entrySlug}
>
  <button type="button" class="vpc-coupon-popup__backdrop" aria-label="Dismiss discount confirmation" tabindex="-1"></button>
  <div class="vpc-coupon-popup__panel">
    <p class="vpc-coupon-popup__badge">{msg.badge}</p>
    <h3 class="vpc-coupon-popup__title" id={`${popupId}-title`}>{msg.headline}</h3>
    <p class="vpc-coupon-popup__sub">
      Your flash discount is reserved in this session. Adjust the stress slider to see illustrative exposure with
      protection aligned.
    </p>
    <button type="button" class="vpc-coupon-popup__dismiss" data-vpc-popup-dismiss>Continue to calculator</button>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = "vpc-flash-claim";
    var shown = false;
    var popup = document.getElementById("vpc-coupon-popup");
    if (!popup) return;
    var calcId = popup.getAttribute("data-vpc-target") || "";
    var slug = popup.getAttribute("data-flash-slug") || "";
    var onceKey = "vpc-flash-popup-" + slug;

    function show() {
      if (shown) return;
      try {
        if (sessionStorage.getItem(onceKey)) return;
      } catch (e) {}
      shown = true;
      try {
        sessionStorage.setItem(onceKey, "1");
      } catch (e) {}
      popup.removeAttribute("hidden");
      popup.classList.add("vpc-coupon-popup--open");
      var calc = calcId
        ? document.getElementById(calcId)
        : document.querySelector(".value-protection-calculator");
      if (calc) {
        calc.classList.add("value-protection-calculator--coupon-applied");
        try {
          calc.scrollIntoView({ behavior: "smooth", block: "nearest" });
        } catch (e) {
          calc.scrollIntoView(true);
        }
      }
      document.body.classList.add("vpc-coupon-popup-open");
    }

    function hide() {
      popup.classList.remove("vpc-coupon-popup--open");
      popup.setAttribute("hidden", "");
      document.body.classList.remove("vpc-coupon-popup-open");
    }

    document.querySelectorAll('.pest-flash-offer__cta[href^="tel:"]').forEach(function (a) {
      a.addEventListener("click", function () {
        try {
          sessionStorage.setItem(KEY, String(Date.now()));
        } catch (e) {}
      });
    });

    function maybe() {
      if (shown) return;
      var t = 0;
      try {
        t = parseInt(sessionStorage.getItem(KEY) || "0", 10);
      } catch (e) {}
      if (!t) return;
      var dt = Date.now() - t;
      if (dt < 800) return;
      if (dt > 120000) {
        try {
          sessionStorage.removeItem(KEY);
        } catch (e) {}
        return;
      }
      try {
        sessionStorage.removeItem(KEY);
      } catch (e) {}
      show();
    }

    document.addEventListener("visibilitychange", function () {
      if (document.visibilityState === "visible") maybe();
    });
    window.addEventListener("pageshow", function () {
      maybe();
    });
    window.addEventListener("focus", function () {
      maybe();
    });

    var dismiss = popup.querySelector("[data-vpc-popup-dismiss]");
    if (dismiss) dismiss.addEventListener("click", hide);
    var backdrop = popup.querySelector(".vpc-coupon-popup__backdrop");
    if (backdrop) backdrop.addEventListener("click", hide);
  })();
</script>

<style is:global>
  .vpc-coupon-popup {
    position: fixed;
    inset: 0;
    z-index: 12000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    box-sizing: border-box;
  }
  .vpc-coupon-popup--open {
    display: flex;
  }
  .vpc-coupon-popup__backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    padding: 0;
    margin: 0;
    background: rgba(15, 23, 42, 0.55);
    cursor: pointer;
  }
  .vpc-coupon-popup__panel {
    position: relative;
    z-index: 1;
    width: min(420px, 94vw);
    padding: 1.15rem 1.2rem 1.05rem;
    border-radius: 14px;
    background: linear-gradient(160deg, #fff 0%, #fef2f2 100%);
    border: 2px solid #b91c1c;
    box-shadow: 0 18px 48px rgba(127, 29, 29, 0.28);
    text-align: center;
  }
  .vpc-coupon-popup__badge {
    margin: 0 0 0.45rem;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #b91c1c;
  }
  .vpc-coupon-popup__title {
    margin: 0 0 0.55rem;
    font-size: 1.08rem;
    line-height: 1.4;
    font-weight: 800;
    color: #0f172a;
  }
  .vpc-coupon-popup__sub {
    margin: 0 0 0.85rem;
    font-size: 0.88rem;
    line-height: 1.45;
    color: #475569;
  }
  .vpc-coupon-popup__dismiss {
    display: inline-block;
    width: 100%;
    padding: 0.55rem 0.85rem;
    border: 0;
    border-radius: 999px;
    background: #b91c1c;
    color: #fff;
    font-weight: 800;
    font-size: 0.9rem;
    cursor: pointer;
  }
  .vpc-coupon-popup__dismiss:hover {
    background: #991b1b;
  }
  body.vpc-coupon-popup-open {
    overflow: hidden;
  }
  .value-protection-calculator--coupon-applied {
    outline: 3px solid rgba(185, 28, 28, 0.45);
    outline-offset: 3px;
    box-shadow:
      0 14px 40px rgba(15, 23, 42, 0.12),
      0 0 0 4px rgba(254, 202, 202, 0.55);
    transition: box-shadow 0.35s ease, outline-color 0.35s ease;
  }
</style>
