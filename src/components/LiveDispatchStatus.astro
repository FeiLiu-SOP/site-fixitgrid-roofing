---
import { buildLiveDispatchStatusProps, liveDispatchStatusEnabled } from "../lib/live-dispatch-status";

interface Props {
  city: string;
  stateCode: string | null;
  entrySlug: string;
  lat?: number;
  lng?: number;
}

const { city, stateCode, entrySlug, lat, lng } = Astro.props;

const enabled = liveDispatchStatusEnabled();
const model = enabled ? buildLiveDispatchStatusProps({ city, stateCode, entrySlug, lat, lng }) : null;
---

{
  model ? (
    <div
      class="live-dispatch-status live-dispatch-status--loading"
      role="status"
      aria-live="polite"
      data-live-dispatch-status
      data-city={model.city}
      data-tz={model.tz}
      data-opens-min={String(model.opensMin)}
      data-closes-min={String(model.closesMin)}
    >
      <span class="live-dispatch-status__dot" aria-hidden="true" />
      <span class="live-dispatch-status__text">Checking local dispatch window…</span>
      <span class="live-dispatch-status__hours">
        Local hours: {model.displayRange}
      </span>
      {
        import.meta.env.DEV ? (
          <p class="live-dispatch-status__preview-hint">
            Dev only: append <code>?liveStatus=open</code> or <code>?liveStatus=after</code> to force a state.
            View JSON-LD: page source → search <code>openingHoursSpecification</code>.
          </p>
        ) : null
      }
    </div>
  ) : null
}

{
  model ? (
    <script is:inline>
      (function () {
        function localMinutes(tz) {
          var parts = new Intl.DateTimeFormat("en-US", {
            timeZone: tz,
            hour: "numeric",
            minute: "numeric",
            hour12: false,
          }).formatToParts(new Date());
          var h = 0;
          var m = 0;
          for (var i = 0; i < parts.length; i++) {
            if (parts[i].type === "hour") h = parseInt(parts[i].value, 10);
            if (parts[i].type === "minute") m = parseInt(parts[i].value, 10);
          }
          return h * 60 + m;
        }

        function apply(el, open, city) {
          el.classList.remove("live-dispatch-status--loading");
          el.classList.toggle("live-dispatch-status--open", open);
          el.classList.toggle("live-dispatch-status--after", !open);
          var text = el.querySelector(".live-dispatch-status__text");
          if (!text) return;
          text.textContent = open
            ? "STATUS: OPEN — Local Crews Active in " + city
            : "STATUS: AFTER-HOURS EMERGENCY DISPATCH ACTIVE";
        }

        document.querySelectorAll("[data-live-dispatch-status]").forEach(function (el) {
          var city = el.getAttribute("data-city") || "Area";
          var tz = el.getAttribute("data-tz") || "America/New_York";
          var opens = parseInt(el.getAttribute("data-opens-min") || "480", 10);
          var closes = parseInt(el.getAttribute("data-closes-min") || "1050", 10);
          var force = new URLSearchParams(window.location.search).get("liveStatus");
          if (force === "open") return apply(el, true, city);
          if (force === "after" || force === "closed") return apply(el, false, city);
          var now = localMinutes(tz);
          var open = now >= opens && now < closes;
          apply(el, open, city);
        });
      })();
    </script>
  ) : null
}

<style>
  .live-dispatch-status {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    margin: 0.75rem 0 1rem;
    padding: 0.65rem 0.85rem;
    border-radius: 8px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    background: #f8fafc;
    font-size: 0.9rem;
    line-height: 1.35;
  }

  .live-dispatch-status__dot {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    flex-shrink: 0;
    background: #94a3b8;
    animation: live-dispatch-pulse 1.4s ease-in-out infinite;
  }

  .live-dispatch-status--open {
    border-color: rgba(22, 163, 74, 0.45);
    background: #f0fdf4;
  }

  .live-dispatch-status--open .live-dispatch-status__dot {
    background: #16a34a;
    box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.55);
  }

  .live-dispatch-status--after {
    border-color: rgba(234, 88, 12, 0.45);
    background: #fff7ed;
  }

  .live-dispatch-status--after .live-dispatch-status__dot {
    background: #ea580c;
    box-shadow: 0 0 0 0 rgba(234, 88, 12, 0.5);
  }

  .live-dispatch-status__text {
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-size: 0.78rem;
  }

  .live-dispatch-status__hours {
    width: 100%;
    font-size: 0.75rem;
    color: #64748b;
  }

  .live-dispatch-status__preview-hint {
    width: 100%;
    margin: 0;
    font-size: 0.72rem;
    color: #94a3b8;
  }

  .live-dispatch-status__preview-hint code {
    font-size: 0.7rem;
    background: #e2e8f0;
    padding: 0.1rem 0.25rem;
    border-radius: 3px;
  }

  @keyframes live-dispatch-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.55;
      transform: scale(1.15);
    }
  }

  html.fixitgrid-dispatch-shell .live-dispatch-status {
    border-radius: 4px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
</style>
